  "profile": {
    "spatialLogic": "温泉镇沿狭窄河谷组织，旅馆与公共浴场分布在河流两侧，桥梁和坡道串联各处露天风吕；移动本身就是环境体验的一部分。",
    "baseAreas": [
      {
        "name": "温泉街中心",
        "fit": "步行最方便，适合使用温泉手形串联多家露天浴池。"
      },
      {
        "name": "田之原川沿岸",
        "fit": "河流、树林与露天风吕关系最清晰，但热门旅馆价格较高。"
      },
      {
        "name": "南小国外围",
        "fit": "有机会降低住宿费，需要巴士、接驳或自驾往返温泉街。"
      }
    ],
    "waterAccess": "住宿旅馆通常自带温泉；购买入汤手形后可在指定旅馆中选择露天风吕，河流则作为街道与浴场之间的连续景观。",
    "access": "可由福冈、熊本、别府或阿苏乘高速巴士或自驾抵达；镇内适合步行，但坡道和石阶较多。",
    "season": "春夏绿色最浓，秋季红叶热门，冬季泡汤氛围突出；不同季节的植被包裹感差异较大。",
    "stayStrategy": "选择价格较低的素泊或外围旅馆，再使用温泉手形进入环境较好的露天浴场；含餐旅馆应比较是否按人计价。"
  },
