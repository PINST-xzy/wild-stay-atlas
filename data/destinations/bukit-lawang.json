  "profile": {
    "spatialLogic": "村落沿 Bahorok 河狭长展开，一侧是道路与居民区，另一侧逐渐进入勒塞尔山国家公园；吊桥、河岸小径和临水木屋组成连续移动网络。",
    "baseAreas": [
      {
        "name": "国家公园入口上游",
        "fit": "树冠最密、步行感最强，住宿更贴近雨林，但搬运行李较麻烦。"
      },
      {
        "name": "Bahorok 河中段",
        "fit": "河岸客房、餐饮和过桥动线平衡，适合第一次入住。"
      },
      {
        "name": "村口与下游",
        "fit": "车辆抵达方便、价格低，雨林包裹感相对弱一些。"
      }
    ],
    "waterAccess": "村内多处可接近河滩，常见游泳、轮胎漂流与跨河吊桥；进入雨林后还有支流和营地水边活动。",
    "access": "通常从棉兰机场或市区乘车约4至5小时；抵达村口后，部分住宿只能沿河岸小径步行进入。",
    "season": "全年湿热，降雨会影响河水流速和徒步路况；相对干燥月份更适合初次前往。",
    "stayStrategy": "优先选择河岸中上游、实景照片能看见树冠与步道关系的基础木屋，不必为豪华设施提高预算。"
  },
