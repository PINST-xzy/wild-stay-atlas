  "editorial": {
    "oneLine": "考索村的河流雨林与乔兰湖的船行水面构成两段式体验，基础木屋和筏屋已经足以进入环境核心。",
    "reason": "这里需要拆成两个落脚系统理解：考索村适合住河边、进入雨林和参加漂流；乔兰湖则依靠长尾船进入支流与漂浮筏屋。水不是酒店附属设施，而是交通、活动和住宿的共同底层结构。高价住宿能改善空调和卫浴，却不是获得湖面体验的唯一入口。",
    "advantages": [
      "河流、湖面、支流、洞穴和雨林形成连续的水陆体验",
      "基础筏屋价格较低，打开房门即可接近公共湖面",
      "考索村有多档住宿，可用陆上住宿降低整体预算"
    ],
    "disadvantages": [
      {
        "level": "明显取舍",
        "text": "乔兰湖是人工水库，并非天然湖泊。"
      },
      {
        "level": "明显取舍",
        "text": "多数基础筏屋只有风扇或共用卫浴，木栈道与隔音条件有限。"
      },
      {
        "level": "明显取舍",
        "text": "湖区只能乘船移动，房价外还可能产生船费、门票和餐食费用。"
      }
    ]
  },
  "profile": {
    "spatialLogic": "考索村沿河谷展开，陆上住宿连接雨林步道、河流活动和公园入口；乔兰湖内部没有道路，长尾船、筏屋平台和支流水面组成主要动线。",
    "baseAreas": [
      {
        "name": "Khao Sok Village",
        "fit": "交通、餐饮与低价住宿最方便，适合作为雨林河谷基地。"
      },
      {
        "name": "Sok River 河畔",
        "fit": "可直接接近河流与树冠，适合选择简单木屋或树屋。"
      },
      {
        "name": "Khlong Long / Khlong Ka",
        "fit": "湖上筏屋较集中，需综合船程与套餐选择。"
      }
    ],
    "waterAccess": "考索村一带可参加独木舟、漂流或河边活动；湖上住宿通常提供皮划艇，并可直接从平台下水，船程进入不同支流与洞穴。",
    "access": "可由素叻他尼、普吉、甲米或考拉乘车到考索村；乔兰湖需从 Ratchaprapha 码头换乘长尾船。",
    "season": "雨季森林最浓密但船程更受天气影响；2月至5月高温时，无空调筏屋夜间可能闷热。",
    "stayStrategy": "先住考索村一至两晚，再选择一晚基础或中档筏屋；避免把全部预算放在高价湖景房型。"
  },
