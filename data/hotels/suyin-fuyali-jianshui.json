  "profile": {
    "surroundingsSummary": "位于建水古城核心区，距建水古城、临安府署和文庙都很近，朱家花园、朝阳楼、紫陶店和烧豆腐摊可通过街巷步行串联。",
    "sections": [
      {
        "title": "地理位置与周边",
        "text": "酒店位于云南红河州建水古城核心区域，周边不是自然保护区，而是完整的历史街区。临安府署、文庙、朱家花园、朝阳楼以及大量紫陶和地方小吃店分布在步行范围，住宿的周边魅力来自街巷密度和生活连续性。"
      },
      {
        "title": "场地布局",
        "text": "酒店内部以多进庭院、连廊、灰瓦屋面和局部水景组织空间，客房围绕院落展开。它没有大型公共泳池或广阔园林，而是通过门洞、檐下、转折和尺度较小的庭院形成层层进入的过程。"
      },
      {
        "title": "建筑、水体与植物",
        "text": "建筑语言偏当代中式，以木、石、瓦和暖色灯光营造安静氛围；植物经过精心布置，更接近漂亮园林而非半野生热带植被。水以庭院镜面或小型景观形式出现，不具备游泳和天然接触价值。"
      },
      {
        "title": "抵达与实际条件",
        "text": "从建水站打车进入古城较方便，车辆在古城核心区的通行与停车需提前确认。酒店适合把重心放在步行、餐饮和历史建筑；节假日客流、房价和街道噪声会明显上升，建议避开最拥挤时段。"
      }
    ],
    "spatialRelationship": "从酒店庭院穿过门洞和连廊，再步入古城街巷；沉浸感由室内院落向临安府署、朱家花园和地方餐桌连续扩展。",
    "access": "建水站打车前往古城，最后一段按酒店指引落客；古城内部最适合步行。"
  },
  "food": {
    "summary": "这家的真正亮点是把住宿放进建水味觉地图：汽锅鸡、草芽、烧豆腐、米线和紫陶汽锅都具有明确地域性，美食足以与庭院并列成为主线。",
    "setting": "酒店中式早餐与餐厅可作为起点，更多代表味道分布在步行可达的建水古城街巷。",
    "highlights": [
      {
        "name": "建水汽锅鸡",
        "description": "以紫陶汽锅蒸汽凝结成汤，鸡汤清鲜，是建水最具标识度的菜。"
      },
      {
        "name": "建水烧豆腐",
        "description": "街头炭火慢烤的小块豆腐，蘸干料或蘸水，适合边走边吃。"
      },
      {
        "name": "草芽入馔",
        "description": "建水特有水生蔬菜，可入汤、炒食或配米线，口感清甜脆嫩。"
      },
      {
        "name": "古城早点",
        "description": "米线、卷粉与本地酱料组成很有地方感的早晨，比标准酒店早餐更值得探索。"
      }
    ],
    "caveat": "哪些代表菜由酒店餐厅供应需按当天菜单确认；本页同时记录步行范围内的目的地饮食。"
  },
