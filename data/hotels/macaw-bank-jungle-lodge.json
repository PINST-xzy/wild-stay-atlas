  "profile": {
    "surroundingsSummary": "旅馆位于伯利兹卡约区 Macal 河沿岸，约五十英亩私人保护地中分布农园、河岸和五英里自然小径，周边是低密度热带林与洞穴、玛雅遗址活动区。",
    "sections": [
      {
        "title": "地理位置与周边",
        "text": "旅馆位于圣伊格纳西奥以南的 Macal 河乡野地带，周围没有连续城镇界面，而是河谷、农地和热带森林。这里可作为探索卡约区洞穴、瀑布与玛雅遗址的落脚点，但最直接的周边仍是旅馆自己的河岸与保护地。"
      },
      {
        "title": "场地布局",
        "text": "场地规模约五十英亩，却只设置六栋独立 cabana。住宿、蝴蝶园、菜园、餐厅和河岸之间由林下小径连接，空间松散，没有大型泳池或集中式客房楼；客人需要靠步行认识整个场地。"
      },
      {
        "title": "建筑、水体与植物",
        "text": "小屋使用木材和高脚结构，建筑表达朴素，优势来自树冠和河流。Macal 河边有便于接近的沙质岸线，可下水、漂流或在岸边停留；园地与次生林一直延伸到建筑周围。"
      },
      {
        "title": "抵达与实际条件",
        "text": "从圣伊格纳西奥前往需要车辆并提前确认路线，现场以太阳能等低影响设施为主。餐食多按固定菜单和时间供应，房间数量少，旺季需要提前订；追求酒店式硬件的人会明显感到简单。"
      }
    ],
    "spatialRelationship": "小屋散落在林中，步道经过花园与餐厅后下降到 Macal 河沙岸，河流是场地边界也是活动中心。",
    "access": "从圣伊格纳西奥包车或自驾进入乡间道路；不建议依赖临时叫车。"
  },
  "food": {
    "summary": "六间小屋共享的餐桌走家庭式路线，以农园和当地有机食材为基础，一日三餐按固定菜单准备，胜在新鲜、有人情味和场地关联。",
    "setting": "开放餐厅面向花园与丛林，住客在相近时间共同用餐。",
    "highlights": [
      {
        "name": "伯利兹家常晚餐",
        "description": "米饭、豆类、鸡肉或鱼与当季蔬菜组合，味道直接而不繁复。"
      },
      {
        "name": "农园蔬菜",
        "description": "旅馆菜园供应部分香草和蔬菜，菜单随收成调整。"
      },
      {
        "name": "饮食适配",
        "description": "可提前沟通素食等需求，小规模厨房更偏预约式准备。"
      }
    ],
    "caveat": "不是可随时点单的度假村餐厅，固定菜单和用餐时间需要提前确认。"
  },
