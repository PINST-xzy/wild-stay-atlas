  "editorial": {
    "oneLine": "乘船穿过豆蔻山河道才能抵达的十二帐营地，皮划艇、游泳和巡护步道构成完整的保护区生活。",
    "reason": "它满足沉浸感，但预算口径特殊：不是普通一晚房价，而是含船、向导和餐食的多日套餐。帐篷设施简单，换来的是河岸、密林和保护区巡护的连续体验，因此作为高取舍收藏保留。",
    "advantages": [
      "必须乘船进入，抵达过程本身即进入保护区",
      "河流可划艇、游泳，林径与巡护活动直接从营地展开",
      "小规模十二顶帐篷，建筑存在感低"
    ],
    "disadvantages": [
      {
        "level": "明显取舍",
        "text": "按人计价的多日套餐容易超过普通酒店预算"
      },
      {
        "level": "轻微提醒",
        "text": "高湿、昆虫、简单设施和固定活动节奏不可避免"
      }
    ],
    "fit": "愿意把住宿预算支付给保护区、向导和完整活动的人。",
    "notFit": "只想自由订一晚、需要空调泳池或精致客房的人。"
  },
  "profile": {
    "surroundingsSummary": "营地位于柬埔寨西南部豆蔻山脉 Botum Sakor 国家公园范围内，Preak Tachan 河、常绿林和野生动物保护区构成唯一周边。",
    "sections": [
      {
        "title": "地理位置与周边",
        "text": "营地位于国公省豆蔻山保护地深处，周边没有传统度假区和商业设施。客人通常在 Trapeang Rung 集合后换船沿河进入，河道、密林、巡护站和野生动物栖息地共同构成住宿范围。"
      },
      {
        "title": "场地布局",
        "text": "十二顶 safari tent 沿 Preak Tachan 河岸分布，以木平台、开放餐亭和小径连接。没有大型前台、泳池或景观轴线，日常动线围绕码头、河岸、餐厅和进入保护区的徒步线路展开。"
      },
      {
        "title": "建筑、水体与植物",
        "text": "帐篷抬离湿地地面，使用帆布与木平台，体量低且容易被植物遮住。河流就在营地旁，可下水游泳或划皮艇；雨季水位、浑浊度和活动安全条件会随天气变化。"
      },
      {
        "title": "抵达与实际条件",
        "text": "一般需要购买至少三天两夜或四天三夜套餐，船、向导、餐食和保育活动打包计价。抵达时间固定，错过集合会很麻烦；网络、空调和城市服务都不应作为默认条件。"
      }
    ],
    "spatialRelationship": "码头—帐篷—河边餐亭—皮划艇下水点—保护区步道全部围绕河岸展开，水路也是唯一清晰的抵达轴。",
    "access": "从集合点乘船约三十分钟进入；必须严格按营地提供的接驳时间安排行程。"
  },
  "food": {
    "summary": "套餐含一日三餐，餐饮并非奢华卖点，而是河岸活动与巡护行程的完整补给；简单高棉风味在偏远环境里更显合适。",
    "setting": "开放餐亭紧邻河岸，住客按行程共同用餐，水声和林声是场景主体。",
    "highlights": [
      {
        "name": "高棉家常菜",
        "description": "米饭、蔬菜、鸡肉或鱼类以清爽香料烹调，适合炎热潮湿环境。"
      },
      {
        "name": "全包活动餐",
        "description": "多日套餐通常覆盖八餐左右，徒步和划艇行程会配合安排。"
      }
    ],
    "caveat": "菜单和用餐时间跟随套餐，特殊饮食必须在抵达前沟通。"
  },
