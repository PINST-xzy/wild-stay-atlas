  "profile": {
    "surroundingsSummary": "位于雪兰莪乌鲁冷岳的三英亩 hobby farm，旁边是清澈溪流与森林保留地，离吉隆坡不算遥远但现场已经是低密度山林农庄环境。",
    "sections": [
      {
        "title": "地理位置与周边",
        "text": "民宿位于吉隆坡东南侧的乌鲁冷岳乡野，三英亩农庄沿清澈溪流展开，旁边可见森林保留地、竹林和果树。它仍可从城市周末抵达，却没有城市酒店的街道与商业噪声，周边活动以河边停留和农庄生活为主。"
      },
      {
        "title": "场地布局",
        "text": "主体是整栋现代小屋与若干农庄空间，适合约八人共同使用。厨房、客厅、露台、草木庭院和溪流之间距离很短，公共活动集中而亲密；它更像被自然包住的朋友之家，不是分散式度假村。"
      },
      {
        "title": "建筑、水体与植物",
        "text": "玻璃、钢与木构成的小屋抬在地面和岩石旁，大窗把竹林与溪水带进室内。建筑比传统生态旅馆更现代，但体量小，植物仍占主导；溪流可亲近，水况与安全要根据降雨现场判断。"
      },
      {
        "title": "抵达与实际条件",
        "text": "通常整栋出租，需要提前确认人数、入住规则、押金和是否提供床品餐具。这里强调清真友好，禁止酒精；餐饮更适合自炊、烧烤或提前预约，叫车和临时采购都不如城市方便。"
      }
    ],
    "spatialRelationship": "客厅与露台面向溪流，几步即可下到巨石水岸，农庄和竹林在另一侧围合，动线简单但包裹感强。",
    "access": "从吉隆坡自驾约一至两小时，最后进入乡村道路；整团共乘车辆最方便。"
  },
  "food": {
    "summary": "这里的美食吸引力来自朋友共同使用厨房、烧烤区与农庄，而不是餐厅菜单；适合把当地食材和聚会餐桌做成住宿核心。",
    "setting": "整栋厨房、露台和户外区域由住客共同使用，可预约或自备清真食材。",
    "highlights": [
      {
        "name": "朋友烧烤",
        "description": "溪边与农庄环境适合多人烧烤，食材与设备细节需向房东确认。"
      },
      {
        "name": "自炊早餐",
        "description": "完整包栋让早餐时间自由，可在露台边看溪流边准备。"
      }
    ],
    "caveat": "禁止酒精；餐食与调味多需自备，预订前要确认厨房设备和清真规则。"
  },
